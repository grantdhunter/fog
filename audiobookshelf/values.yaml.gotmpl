env:
  TZ: America/Edmonton
ingress:
  main:
    enabled: true
    hosts:
      - host: audiobookshelf.incngrnt.ca
        paths:
        - path: /
    tls:
      - secretName: audiobookshelf-incngrnt-ca-tls
        hosts:
          - audiobookshelf.incngrnt.ca

persistence:
  config:
    enabled: true
    accessMode: ReadWriteOnce
    size: 10Mi
    storageClassName: ceph-block      
  metadata:
    enabled: true
    accessMode: ReadWriteOnce
    size: 5Gi
    storageClassName: ceph-block      
  media:
    enabled: true
    accessMode: ReadWriteOnce
    size: 75Gi
    storageClassName: ceph-block      
